{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./",
    "rootDir": "./"
  },  
  "include": ["functions/**/*"],
  "exclude": [
    "node_modules",
    "dist"
  ]
}